  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    String   @default("new")

  companyName String?
  companyEstablished String?
  companySize String?
  industry String?
  industryOther String?
  companyDescription String?
  companyLocation String?
  companyWebsite String?
  companySocialMedia String?
  contactName String?
  contactPosition String?
  contactPositionOther String?
  contactEmail String?
  contactPhone String?
  contactWhatsApp String?

  vision String?
  mission String?
  coreValues String?
  coreValuesOther String?
  uniqueSellingProposition String?
  brandPersonality String?
  brandPersonalityOther String?

  targetAudienceDescription String?
  audienceAge String?
  audienceGender String?
  audienceLocation String?
  audienceIncome String?
  audienceEducation String?
  audienceOccupation String?
  audienceInterests String?
  audiencePainPoints String?
  audienceBehavior String?
  audienceBuyingJourney String?
