  hasEcommerce Boolean @default(false)
  productTypes String?
  productCount String?
  paymentMethods String?
  shippingMethods String?
  taxRequirements String?
  inventoryManagement Boolean @default(false)

  designStyle String?
  designStyleOther String?
  colorPalette String?
  customColorHex String?
  existingBrandGuidelines String?
  logoProvided Boolean @default(false)
  logoFileName String?
  logoLink String?
  designReferences String?
  designAvoid String?

  pages String?
  customPages String?
  navigationStructure String?
  navigationStructureOther String?

  contentReady String?
